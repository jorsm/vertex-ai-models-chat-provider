{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "npm: bundle-dev",
			"type": "npm",
			"script": "bundle-dev",
			"group": "build",
			"problemMatcher": []
		},
		{
			"label": "npm: watch-bundle",
			"type": "npm",
			"script": "watch-bundle",
			"isBackground": true,
			"group": "build",
			"problemMatcher": []
		}
	]
}